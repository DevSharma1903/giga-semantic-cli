{
  "name": "giga-semantic-cli",
  "version": "1.0.3",
  "description": "Git-Grounded Autonomous AI Self-Healing Coding Agent",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "giga": "./dist/binaries/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "author": "Dev Sharma",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/devsh/giga.git"
  },
  "scripts": {
    "test": "vitest run",
    "build": "tsc && node scripts/build-dist.js",
    "build:binary": "bun build ./src/cli.ts --target=node --outfile=./dist/binaries/cli.js && node -e \"const fs = require('fs'); const file = './dist/binaries/cli.js'; const data = fs.readFileSync(file); const shebang = Buffer.from('#!/usr/bin/env node\\n'); if (!data.toString().startsWith('#!')) { fs.writeFileSync(file, Buffer.concat([shebang, data])); }\"",
    "dashboard": "npx tsx src/server.ts"
  },
  "dependencies": {
    "@clack/prompts": "^1.7.0",
    "@google/genai": "^2.10.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "express": "^5.2.1",
    "octokit": "^4.0.2",
    "ora": "^9.4.1",
    "simple-git": "^3.27.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^20.14.9",
    "pkg": "^5.8.1",
    "tsx": "^4.19.0",
    "typescript": "^5.5.2",
    "vitest": "^1.6.0"
  },
  "pkg": {
    "scripts": "dist/**/*.js",
    "assets": [
      "node_modules/@clack/prompts/**/*"
    ],
    "targets": [
      "node18-win-x64",
      "node18-macos-x64",
      "node18-linux-x64"
    ]
  }
}
